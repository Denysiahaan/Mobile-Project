<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme -->
    <style name="Base.Theme.ReadQRCodes" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/primary_container</item>
        <item name="colorOnPrimaryContainer">@color/primary</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorTertiary">@color/tertiary</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:fontFamily">@font/hanken_grotesk</item>
        <item name="materialCardViewStyle">@style/Widget.ReadQRCodes.Card</item>
        <item name="materialButtonStyle">@style/Widget.ReadQRCodes.Button</item>
        <item name="bottomNavigationStyle">@style/Widget.ReadQRCodes.BottomNavigation</item>
    </style>

    <style name="Theme.ReadQRCodes" parent="Base.Theme.ReadQRCodes" />

    <!-- TEMA SPLASH SCREEN: Mengganti robot hijau dengan logo Anda -->
    <style name="Theme.ReadQRCodes.Splash" parent="Theme.SplashScreen">
        <!-- Menggunakan logo kustom Anda alih-alih robot hijau -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/logo</item>
        <!-- Background warna biru agar menyatu dengan SplashActivity -->
        <item name="windowSplashScreenBackground">@color/primary</item>
        <!-- Tema yang akan dipasang setelah loading sistem selesai -->
        <item name="postSplashScreenTheme">@style/Theme.ReadQRCodes</item>

        <item name="android:statusBarColor">@color/primary</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Card Style -->
    <style name="Widget.ReadQRCodes.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">0dp</item>
        <item name="cardBackgroundColor">@color/surface</item>
    </style>

    <!-- Button Style -->
    <style name="Widget.ReadQRCodes.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">16dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Navigation Style -->
    <style name="Widget.ReadQRCodes.BottomNavigation" parent="Widget.Material3.BottomNavigationView">
        <item name="backgroundTint">@color/surface</item>
        <item name="itemIconTint">@color/primary</item>
        <item name="itemTextColor">@color/primary</item>
        <item name="itemActiveIndicatorStyle">@style/Widget.ReadQRCodes.ActiveIndicator</item>
        <item name="labelVisibilityMode">labeled</item>
    </style>

    <style name="Widget.ReadQRCodes.ActiveIndicator" parent="">
        <item name="android:color">@color/nav_active_indicator</item>
    </style>
</resources>
