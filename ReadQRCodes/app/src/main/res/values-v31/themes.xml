<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Perbaikan agar logo robot hijau tidak muncul di Android 12+ -->
    <style name="Theme.ReadQRCodes.Splash" parent="Theme.SplashScreen">
        <!-- Membuat ikon sistem transparan agar langsung fokus ke logo di desain kustom Anda -->
        <item name="android:windowSplashScreenAnimatedIcon">@android:color/transparent</item>

        <!-- Background warna biru agar selaras dengan desain SplashActivity Anda -->
        <item name="android:windowSplashScreenBackground">@color/primary</item>

        <!-- Tema yang akan dipasang setelah loading sistem selesai -->
        <item name="postSplashScreenTheme">@style/Theme.ReadQRCodes</item>

        <item name="android:statusBarColor">@color/primary</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
