<?xml version="1.0" encoding="utf-8"?>
<!-- MaterialCardView: Memberikan tampilan dialog yang modern dengan sudut membulat -->
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="28dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Judul Dialog (Tambah atau Edit) -->
        <TextView
            android:id="@+id/tv_dialog_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/add_task"
            android:textAppearance="?attr/textAppearanceTitleLarge"
            android:textStyle="bold"
            android:textColor="?attr/colorPrimary" />

        <!-- TextInputLayout: Kontainer input teks dengan label melayang (Floating Label) -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:hint="@string/task_title_label"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_task_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapSentences" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Label Prioritas -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/priority"
            android:textAppearance="?attr/textAppearanceLabelMedium" />

        <!-- Toggle Group: Pilihan prioritas (Penting, Sedang, Ringan) -->
        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggle_priority"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:singleSelection="true"
            app:selectionRequired="true">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_priority_high"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/penting" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_priority_medium"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/sedang" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_priority_low"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/ringan" />
        </com.google.android.material.button.MaterialButtonToggleGroup>

        <!-- Tombol untuk membuka DatePicker (Atur Deadline) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_set_deadline"
            style="?attr/materialIconButtonFilledTonalStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/set_deadline"
            app:icon="@android:drawable/ic_menu_today"
            android:gravity="start|center_vertical" />

        <!-- Menampilkan tanggal deadline yang telah dipilih -->
        <TextView
            android:id="@+id/tv_selected_deadline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_gravity="end"
            android:text="Pilih Tanggal"
            android:textAppearance="?attr/textAppearanceBodySmall" />

        <!-- Tombol Aksi (Batal dan Simpan) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:gravity="end"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_cancel"
                style="?attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/cancel" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/save" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>